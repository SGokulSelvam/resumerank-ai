# Copy this file to .env and fill in your values
# cp .env.example .env

# ── REQUIRED ───────────────────────────────────────────
# Your Anthropic API key — get it at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OPTIONAL ───────────────────────────────────────────
# Pro access token — give this to paying users to bypass rate limits
# Generate any random secret string
PRO_TOKEN=change_this_to_a_secret_string

# ── STRIPE (for payments) ───────────────────────────────
# Sign up at https://stripe.com and get these from your dashboard
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
